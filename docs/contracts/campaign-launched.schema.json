{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CampaignLaunched",
  "type": "object",
  "properties": {
    "eventType": { "const": "CampaignLaunched" },
    "eventId": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string" },
    "campaign": {
      "type": "object",
      "properties": {
        "campaignId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "startAt": { "type": "string", "format": "date-time" }
      },
      "required": ["campaignId","name"]
    }
  },
  "required": ["eventType","eventId","occurredAt","tenantId","campaign"]
}
